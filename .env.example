# Vinyl Scrobbler — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Required — your ListenBrainz API token
LISTENBRAINZ_TOKEN=

# ALSA device — find yours with: arecord -l
ALSA_DEVICE=hw:0,0

# Silence detection threshold (RMS amplitude)
# Lower = more sensitive. Default 500 works for EPOS B20 in a quiet room.
SILENCE_THRESHOLD=500

# Consecutive above-threshold checks before triggering recognition.
# Higher = fewer false triggers from conversation/transient sounds.
# At 1s per check, 3 means ~3 seconds of sustained audio required.
SUSTAINED_AUDIO_CHECKS=3

# RMS stride — check every Nth sample for silence detection.
# Higher = faster but less precise. 16 is a good default for Pi.
RMS_STRIDE=16

# Cooldown between recognition cycles (seconds).
# Limits how often fingerprints are sent to Shazam.
RECOGNITION_COOLDOWN=10

# Backoff after failed recognition — base seconds and max cap.
# Exponential: 30s, 60s, 120s, 240s, 300s (capped).
FAILURE_BACKOFF_BASE=30
FAILURE_BACKOFF_MAX=300

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
